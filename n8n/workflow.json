      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const original = $('Normalizar Payload').first().json;\nconst api = items[0].json;\nconst capitalSocialNum = Number((api.capital_social || '0').toString().replace(/\\./g, '').replace(',', '.')) || 0;\n\nreturn [{\n  json: {\n    ...original,\n    razao_social: api.razao_social || api.nome_fantasia || '',\n    cnae_descricao: api.cnae_principal || '',\n    porte: api.porte_empresa || '',\n    situacao_cadastral: api.situacao_cadastral || '',\n    capital_social: capitalSocialNum,\n    fonte_enriquecimento: 'OpenCNPJ'\n  }\n}];"
      },
      "id": "a8d47298-1d61-4400-a08d-5b51d93d48b8",
      "name": "Formatar Dados OpenCNPJ",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1392, 992]
    },
    {
      "parameters": {
        "jsCode": "const item = items[0].json;\nconst ticket = Number(item.ticket_medio_mensal) || 0;\n\nlet tier = 'desqualificado';\nif (ticket > 10000) tier = 'quente';\nelse if (ticket >= 5000) tier = 'atencao';\n\n// Valores INTERNOS (não os rótulos) das opções da propriedade nativa\n// hs_lead_status no HubSpot. Confira em Configurações > Propriedades >\n// Propriedades de contato > Status do lead antes de ativar.\nconst HUBSPOT_LEAD_STATUS = {\n  quente: 'Oportunidade',\n  atencao: 'Oportunidade',\n  desqualificado: 'Nutrir'\n};\n\nreturn [{\n  json: {\n    ...item,\n    tier,\n    hs_lead_status: HUBSPOT_LEAD_STATUS[tier],\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "9f0aab5e-fc14-4f91-b3e2-fc8b02ea6910",
      "name": "Calcular Classificação",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1584, 832]
    },
    {
      "parameters": {
        "jsCode": "const item = items[0].json;\n\nconst systemPrompt = 'Você é um SDR da Driva, uma plataforma de inteligência de mercado B2B. Dado os dados de uma empresa que preencheu um formulário de contato, responda SOMENTE em JSON válido com duas chaves: resumo_ia (resumo de 1 a 2 frases sobre a empresa e a oportunidade) e abordagem_sugerida (1 frase com o melhor ângulo de abordagem comercial). Não inclua nenhum texto fora do JSON.';\n\nconst userPrompt = [\n  `Empresa: ${item.razao_social || item.empresa}`,\n  `CNAE: ${item.cnae_descricao}`,\n  `Situação cadastral: ${item.situacao_cadastral}`,\n  `Ticket médio informado: R$ ${item.ticket_medio_mensal}/mês`,\n  `Tier calculado: ${item.tier}`,\n  `Nome do contato: ${item.nome}`\n].join('\\n');\n\nreturn [{\n  json: {\n    ...item,\n    openai_request_body: JSON.stringify({\n      model: 'gpt-4o-mini',\n      response_format: { type: 'json_object' },\n      messages: [\n        { role: 'system', content: systemPrompt },\n        { role: 'user', content: userPrompt }\n      ]\n    })\n  }\n}];"
      },
      "id": "f1a2b3c4-0001-4000-8000-000000000003",
      "name": "Montar Prompt IA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1720, 832]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.openai_request_body }}",
        "options": {}
      },
      "id": "f1a2b3c4-0001-4000-8000-000000000004",
      "name": "OpenAI - Qualificação",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1900, 832],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const original = $('Montar Prompt IA').first().json;\nlet resumo_ia = '';\nlet abordagem_sugerida = '';\n\ntry {\n  const content = items[0].json?.choices?.[0]?.message?.content || '{}';\n  const result = JSON.parse(content);\n  resumo_ia = result.resumo_ia || '';\n  abordagem_sugerida = result.abordagem_sugerida || '';\n} catch (e) {\n  // mantém strings vazias se a IA falhar ou responder fora do formato esperado\n}\n\nconst { openai_request_body, ...rest } = original;\n\nreturn [{\n  json: {\n    ...rest,\n    resumo_ia,\n    abordagem_sugerida\n  }\n}];"
      },
