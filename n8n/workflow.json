        "jsCode": "const original = $('Normalizar Payload').first().json;\nconst api = items[0].json;\n\nreturn [{\n  json: {\n    ...original,\n    razao_social: api.razao_social || api.nome_fantasia || '',\n    cnae_descricao: api.cnae_fiscal_descricao || '',\n    porte: api.porte || '',\n    situacao_cadastral: api.descricao_situacao_cadastral || '',\n    capital_social: Number(api.capital_social) || 0,\n    fonte_enriquecimento: 'BrasilAPI'\n  }\n}];"
      },
