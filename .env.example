# Modelo de referência das credenciais/variáveis usadas nos workflows do n8n.
# Copie para ".env" (já ignorado pelo git) e preencha com os valores reais.
#
# IMPORTANTE: este arquivo é só uma referência pessoal. O n8n NÃO lê este
# arquivo automaticamente — ele roda num servidor separado (Easypanel).
# Os valores reais precisam ser cadastrados em:
#   - Credenciais (OpenAI, HubSpot, Evolution API) -> n8n > Credentials
#   - Variáveis de ambiente (ALLOWED_ORIGIN etc.)   -> n8n > Settings > Environment
#     (ou no painel do Easypanel, nas env vars do serviço do n8n)

# OpenAI - usado no nó de qualificação (resumo_ia / abordagem_sugerida)
OPENAI_API_KEY=

# Evolution API - usado no alerta de WhatsApp para leads quente/atenção
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# HubSpot - usado no upsert de contato/deal
HUBSPOT_PRIVATE_APP_TOKEN=

# Segurança do webhook
ALLOWED_ORIGIN=https://kristhianno.github.io
